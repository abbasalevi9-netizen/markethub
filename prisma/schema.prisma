generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STORE_OWNER
  CUSTOMER
}

enum SubscriptionStatus {
  INACTIVE
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

enum ProductCategory {
  SWEATERS
  PANTS
  SHOES
  THOBES
  SHIRTS
  JACKETS
  DRESSES
  KIDS
  ACCESSORIES
  OTHER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(CUSTOMER)

  accounts      Account[]
  sessions      Session[]

  stores        Store[]
  subscriptions Subscription[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Store {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  description      String?

  location         String?
  websiteUrl       String?
  logoUrl          String?
  bannerUrl        String?
  locationImageUrl String?

  isFeatured       Boolean   @default(false)
  showOnHome       Boolean   @default(true)
  homeSort         Int       @default(0)
  featuredUntil    DateTime?

  isPublished      Boolean   @default(false)

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  products     Product[]
  subscription Subscription?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([isFeatured])
  @@index([showOnHome])
  @@index([homeSort])
}

model Product {
  id          String          @id @default(cuid())
  name        String
  slug        String
  description String?
  imageUrl    String?
  priceCents  Int
  currency    String          @default("usd")
  category    ProductCategory @default(OTHER)
  isActive    Boolean         @default(true)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([category])
}

model Subscription {
  id                   String             @id @default(cuid())
  status               SubscriptionStatus @default(INACTIVE)

  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  stripePriceId        String?
  currentPeriodEnd     DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}